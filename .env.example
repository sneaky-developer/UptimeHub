# UptimeHub Master configuration
# Copy to .env (or set as environment variables) when running the master
# outside docker-compose. docker-compose.yml ships with working dev values.

# ─── App ────────────────────────────────────────────────────────────
# "development" enables relaxed defaults; anything else enforces
# production checks (strong JWT_SECRET required)
APP_ENV=development
APP_PORT=8080

# ─── Database ───────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=uptimehub
DB_PASSWORD=uptimehub_secret
DB_NAME=uptimehub
DB_SSLMODE=disable

# ─── Auth ───────────────────────────────────────────────────────────
# REQUIRED in production: a random string of at least 32 characters
# Generate one with: openssl rand -hex 32
JWT_SECRET=

# Initial admin account, created on first startup only.
# If ADMIN_PASSWORD is empty: development seeds "admin123";
# production generates a random password and prints it once to the logs.
ADMIN_EMAIL=admin@uptimehub.local
ADMIN_PASSWORD=

# ─── Misc ───────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Days to keep raw check results (uptime aggregations are kept forever)
CHECK_RETENTION_DAYS=90
